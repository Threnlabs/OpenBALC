# ─── Supabase Configurations ─────────────────────────────
# Get these from your Supabase Project Settings -> API
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── AI / LLM Configurations ───────────────────────────────
# Required for the ingestion pipeline (automatic embedding + asset captioning).
# Used for:
#   - text-embedding-004  → generates 768-dim vectors for module_chunks (RAG)
#   - gemini-1.5-flash    → generates AI captions for images & tables in sources
# Get your key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your-gemini-api-key
