# ─── Supabase Configurations ─────────────────────────────
# Get these from your Supabase Project Settings -> API
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── AI / LLM Configurations ───────────────────────────────────────────────
# Required for the backend ingestion pipeline (automatic embedding + asset captioning).
# Used for:
#   - text-embedding-004  → generates 768-dim vectors for module_chunks (RAG)
#   - gemini-1.5-flash    → generates AI captions for images & tables in sources
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# (Optional) Required for premium PDF layout, table, and image extraction.
# If omitted, ingestion will fall back to simple client-side pdf.js text extraction.
# Get your key at: https://cloud.llamaindex.ai/
LLAMA_CLOUD_API_KEY=your-llama-cloud-api-key

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  REDIS ARCHITECTURE — TWO SEPARATE LAYERS                               ║
# ║                                                                          ║
# ║  Layer 1 → Upstash (NO VITE_ prefix, secured via api/cache backend proxy)║
# ║             Purpose: data caching for modules, conversations, content    ║
# ║                                                                          ║
# ║  Layer 2 → Redis Cloud (NO VITE_ prefix, server/Python only, TCP)       ║
# ║             Purpose: agent memory, context retriever, LangCache          ║
# ║             Requires: Redis Stack (RediSearch + RedisJSON + Vector)      ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ─── Layer 1: Upstash Redis — Frontend Cache (Via API Proxy) ────────────────
# Get these from: https://console.upstash.com → Create Database → REST API tab
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...your-upstash-rest-token

# ─── Layer 2: Redis Cloud — Python Backend (SERVER ONLY) ───────────────────
# ⚠️  NEVER prefix these with VITE_ — they must NEVER ship to the browser.
# Requires Redis Stack enabled on the database (for RediSearch + Vector).
# Get these from: https://app.redislabs.com → Database → Configuration
#
# Used by: services/redis_client.py, services/langcache.py
REDIS_CLOUD_HOST=redis-xxxxx.c1.us-east-1-2.ec2.redns.redis-cloud.com
REDIS_CLOUD_PORT=6380
REDIS_CLOUD_PASSWORD=your-redis-cloud-password
REDIS_CLOUD_USERNAME=default
REDIS_CLOUD_SSL=true

# ─── context-surfaces — Agent Memory & Context Retriever ───────────────────
# ⚠️  SERVER ONLY — do not prefix with VITE_
# Two separate agent keys: one for read-write memory, one for read-only retriever.
# Get from: ctxctl agent create --surface-id <id> --name "..."
#
# Used by: services/agent_memory.py, services/context_retriever.py
CONTEXT_SURFACES_AGENT_URL=https://api.context.surfaces.dev
CONTEXT_SURFACES_MEMORY_AGENT_KEY=sk-memory-your-key-here
CONTEXT_SURFACES_RETRIEVER_AGENT_KEY=sk-retriever-your-key-here

# ─── LangCache — Semantic LLM Response Cache ───────────────────────────────
# ⚠️  SERVER ONLY
# Controls semantic similarity threshold (0.0–1.0). Higher = stricter matching.
# Default: 0.92 (92% similarity required to serve cached answer)
# Server also needs GEMINI_API_KEY (without VITE_ prefix) for embedding generation.
#
# Used by: services/langcache.py
GEMINI_API_KEY=your-gemini-api-key-server-side
LANGCACHE_TTL=604800
LANGCACHE_SIMILARITY_THRESHOLD=0.92
